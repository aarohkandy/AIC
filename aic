#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export PYTHONPATH="${ROOT_DIR}/backend${PYTHONPATH:+:${PYTHONPATH}}"

PYTHON_BIN="python3"
if [[ -x "${ROOT_DIR}/.venv-test/bin/python" ]]; then
  PYTHON_BIN="${ROOT_DIR}/.venv-test/bin/python"
fi

exec "${PYTHON_BIN}" "${ROOT_DIR}/scripts/aic_tui.py" "$@"
