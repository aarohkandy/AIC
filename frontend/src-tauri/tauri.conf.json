{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI CAD",
  "version": "0.1.0",
  "identifier": "com.aicad.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI CAD",
        "width": 1600,
        "height": 1040,
        "minWidth": 1200,
        "minHeight": 820,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "resources": {
      "../../backend/app/": "backend/app/",
      "../../packaging/runtime/": "runtime/"
    }
  }
}

